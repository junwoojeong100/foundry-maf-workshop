# ------------------------------------------------------------------
# 워크샵 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env
#
# 참고: hosted agent로 "배포(azd)"하면 아래 두 값은 Foundry 호스팅 인프라가
#       컨테이너에 자동 주입합니다. 로컬 실행(local/serve/call) 때만 필요합니다.
# ------------------------------------------------------------------

# [Foundry 포털에서 복사] 프로젝트 엔드포인트
# 형식: https://<리소스이름>.services.ai.azure.com/api/projects/<프로젝트이름>
FOUNDRY_PROJECT_ENDPOINT="https://your-resource.services.ai.azure.com/api/projects/your-project"

# 배포한 모델의 배포 이름 (예: gpt-5.4, gpt-4o 등 포털에서 배포한 이름)
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4"

# [Lab 06 call 모드] 호출할 hosted agent 이름 (각 예제의 agent.manifest.yaml 의 name)
FOUNDRY_AGENT_NAME="maf-basic-agent"
