# 로컬(local/serve/call) 실행용. 이 파일을 .env 로 복사해 값을 채우세요.
# 배포(azd) 후에는 FOUNDRY_PROJECT_ENDPOINT / AZURE_AI_MODEL_DEPLOYMENT_NAME 를
# 호스팅 인프라가 자동 주입하므로 hosted 실행 환경에는 직접 넣지 않아도 됩니다.
FOUNDRY_PROJECT_ENDPOINT="https://your-resource.services.ai.azure.com/api/projects/your-project"
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4"

# call 모드에서 호출할 hosted agent 이름 (`azd ai agent init --agent-name` 값과 일치)
FOUNDRY_AGENT_NAME="maf-basic-agent"
